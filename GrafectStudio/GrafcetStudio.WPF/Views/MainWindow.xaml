<Window x:Class="GrafcetStudio.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:avd="https://github.com/Dirkster99/AvalonDock"
        Title="GRAFCET Studio"
        Height="768" Width="1280"
        MinHeight="480" MinWidth="800"
        FontFamily="Segoe UI"
        Background="{StaticResource BackgroundPrimaryBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        prism:ViewModelLocator.AutoWireViewModel="True">

    <DockPanel LastChildFill="True">

        <!-- Top: Menu bar + ToolBar -->
        <StackPanel DockPanel.Dock="Top"
                    Background="{StaticResource BackgroundTertiaryBrush}">

            <Menu Height="22"
                  Background="{StaticResource BackgroundTertiaryBrush}"
                  Foreground="{StaticResource TextPrimaryBrush}"
                  BorderThickness="0">
                <MenuItem Header="_File">
                    <MenuItem Header="_New"/>
                    <MenuItem Header="_Open..."/>
                    <MenuItem Header="_Save"/>
                    <MenuItem Header="Save _As..."/>
                    <Separator/>
                    <MenuItem Header="E_xit"/>
                </MenuItem>
                <MenuItem Header="_Edit">
                    <MenuItem Header="_Undo"/>
                    <MenuItem Header="_Redo"/>
                </MenuItem>
                <MenuItem Header="_Generate">
                    <MenuItem Header="Keyence Mnemonic (.mnm)"/>
                    <MenuItem Header="Structured Text (.st)"/>
                </MenuItem>
                <MenuItem Header="_Help">
                    <MenuItem Header="_About GRAFCET Studio"/>
                </MenuItem>
            </Menu>

            <ToolBar Height="32"
                     Background="{StaticResource BackgroundTertiaryBrush}"
                     BorderBrush="{StaticResource BorderDefaultBrush}"
                     BorderThickness="0,1,0,0">
                <Button Style="{StaticResource IconButton}" ToolTip="New Document"/>
                <Button Style="{StaticResource IconButton}" ToolTip="Open"/>
                <Button Style="{StaticResource IconButton}" ToolTip="Save"/>
                <Separator/>
                <Button Style="{StaticResource IconButton}" ToolTip="Undo"/>
                <Button Style="{StaticResource IconButton}" ToolTip="Redo"/>
                <Separator/>
                <Button Style="{StaticResource IconButton}" ToolTip="Generate Code"/>
            </ToolBar>

        </StackPanel>

        <!-- Bottom: Status bar -->
        <StatusBar DockPanel.Dock="Bottom"
                   Height="24"
                   Background="{StaticResource AccentPrimaryBrush}"
                   Foreground="{StaticResource AccentForegroundBrush}">
            <StatusBarItem>
                <TextBlock Text="Ready"
                           Foreground="{StaticResource AccentForegroundBrush}"
                           FontSize="12"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Center: AvalonDock layout with professional IDE panels -->
        <avd:DockingManager x:Name="DockManager">
            <avd:DockingManager.Theme>
                <avd:Vs2013LightTheme/>
            </avd:DockingManager.Theme>

            <avd:LayoutRoot>
                <avd:LayoutPanel Orientation="Horizontal">

                    <!-- Left panel: Toolbox -->
                    <avd:LayoutAnchorablePane DockWidth="200">
                        <avd:LayoutAnchorable Title="Toolbox"
                                              CanClose="False"
                                              CanHide="False">
                            <ContentControl prism:RegionManager.RegionName="ToolboxRegion"/>
                        </avd:LayoutAnchorable>
                    </avd:LayoutAnchorablePane>

                    <!-- Center + Bottom: Document pane + Code output -->
                    <avd:LayoutPanel Orientation="Vertical">

                        <!-- Center: Document area (GRAFCET canvas) -->
                        <avd:LayoutDocumentPane>
                            <avd:LayoutDocument Title="Flowchart">
                                <ContentControl prism:RegionManager.RegionName="CanvasRegion"/>
                            </avd:LayoutDocument>
                        </avd:LayoutDocumentPane>

                        <!-- Bottom: Code output -->
                        <avd:LayoutAnchorablePane DockHeight="220">
                            <avd:LayoutAnchorable Title="Code Output"
                                                  CanClose="False">
                                <ContentControl prism:RegionManager.RegionName="CodeRegion"/>
                            </avd:LayoutAnchorable>
                        </avd:LayoutAnchorablePane>

                    </avd:LayoutPanel>

                    <!-- Right panel: Variables + Steps + Transitions + Branches + Properties -->
                    <avd:LayoutAnchorablePane DockWidth="280">
                        <avd:LayoutAnchorable Title="Variables"
                                              CanClose="False">
                            <ContentControl prism:RegionManager.RegionName="VariablesRegion"/>
                        </avd:LayoutAnchorable>

                        <avd:LayoutAnchorable Title="Steps"
                                              CanClose="False">
                            <ContentControl prism:RegionManager.RegionName="StepsRegion"/>
                        </avd:LayoutAnchorable>

                        <avd:LayoutAnchorable Title="Transitions"
                                              CanClose="False">
                            <ContentControl prism:RegionManager.RegionName="TransitionsRegion"/>
                        </avd:LayoutAnchorable>

                        <avd:LayoutAnchorable Title="Branches"
                                              CanClose="False">
                            <ContentControl prism:RegionManager.RegionName="BranchesRegion"/>
                        </avd:LayoutAnchorable>

                        <avd:LayoutAnchorable Title="Properties"
                                              CanClose="False">
                            <ContentControl prism:RegionManager.RegionName="PropertiesRegion"/>
                        </avd:LayoutAnchorable>
                    </avd:LayoutAnchorablePane>

                </avd:LayoutPanel>
            </avd:LayoutRoot>
        </avd:DockingManager>

    </DockPanel>

</Window>
