<Window x:Class="GrafcetStudio.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:prism="http://prismlibrary.com/"
        Title="GRAFCET Studio"
        Height="768" Width="1280"
        MinHeight="480" MinWidth="800"
        FontFamily="Segoe UI"
        Background="{StaticResource BackgroundPrimaryBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        prism:ViewModelLocator.AutoWireViewModel="True">

    <DockPanel LastChildFill="True">

        <!-- Top: Menu bar + ToolBar -->
        <StackPanel DockPanel.Dock="Top"
                    Background="{StaticResource BackgroundTertiaryBrush}">

            <Menu Height="22"
                  Background="{StaticResource BackgroundTertiaryBrush}"
                  Foreground="{StaticResource TextPrimaryBrush}"
                  BorderThickness="0">
                <MenuItem Header="_File">
                    <MenuItem Header="_New"/>
                    <MenuItem Header="_Open..."/>
                    <MenuItem Header="_Save"/>
                    <MenuItem Header="Save _As..."/>
                    <Separator/>
                    <MenuItem Header="E_xit"/>
                </MenuItem>
                <MenuItem Header="_Edit">
                    <MenuItem Header="_Undo"/>
                    <MenuItem Header="_Redo"/>
                </MenuItem>
                <MenuItem Header="_Generate">
                    <MenuItem Header="Keyence Mnemonic (.mnm)"/>
                    <MenuItem Header="Structured Text (.st)"/>
                </MenuItem>
                <MenuItem Header="_Help">
                    <MenuItem Header="_About GRAFCET Studio"/>
                </MenuItem>
            </Menu>

            <ToolBar Height="32"
                     Background="{StaticResource BackgroundTertiaryBrush}"
                     BorderBrush="{StaticResource BorderDefaultBrush}"
                     BorderThickness="0,1,0,0">
                <Button Style="{StaticResource IconButton}" ToolTip="New Document"/>
                <Button Style="{StaticResource IconButton}" ToolTip="Open"/>
                <Button Style="{StaticResource IconButton}" ToolTip="Save"/>
                <Separator/>
                <Button Style="{StaticResource IconButton}" ToolTip="Undo"/>
                <Button Style="{StaticResource IconButton}" ToolTip="Redo"/>
                <Separator/>
                <Button Style="{StaticResource IconButton}" ToolTip="Generate Code"/>
            </ToolBar>

        </StackPanel>

        <!-- Bottom: Status bar -->
        <StatusBar DockPanel.Dock="Bottom"
                   Height="24"
                   Background="{StaticResource AccentPrimaryBrush}"
                   Foreground="{StaticResource AccentForegroundBrush}">
            <StatusBarItem>
                <TextBlock Text="Ready"
                           Foreground="{StaticResource AccentForegroundBrush}"
                           FontSize="12"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Center: Tab views — each tab owns a separate Prism region -->
        <TabControl Background="{StaticResource BackgroundPrimaryBrush}"
                    BorderThickness="0">

            <TabItem Header="Flowchart">
                <ContentControl prism:RegionManager.RegionName="CanvasRegion"/>
            </TabItem>

            <TabItem Header="Variables">
                <ContentControl prism:RegionManager.RegionName="VariablesRegion"/>
            </TabItem>

            <TabItem Header="Code Output">
                <ContentControl prism:RegionManager.RegionName="CodeRegion"/>
            </TabItem>

        </TabControl>

    </DockPanel>

</Window>
