<UserControl x:Class="GrafcetStudio.WPF.Views.PropertiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:models="clr-namespace:GrafcetStudio.Core.Models;assembly=GrafcetStudio.Core"
             prism:ViewModelLocator.AutoWireViewModel="True">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <ObjectDataProvider x:Key="ActionQualifiers"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:ActionQualifier"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground"        Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize"          Value="11"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="8">

            <!-- Nothing selected -->
            <TextBlock Text="Select an element on canvas"
                       Visibility="{Binding IsNothingSelected, Converter={StaticResource BoolToVis}}"
                       Foreground="{StaticResource TextDisabledBrush}"
                       FontStyle="Italic"
                       HorizontalAlignment="Center"
                       Margin="20"/>

            <!-- ── Step section ── -->
            <StackPanel Visibility="{Binding IsStepSelected, Converter={StaticResource BoolToVis}}">

                <TextBlock Text="Step Properties"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>

                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Id"      Style="{StaticResource LabelText}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding StepId}"
                               VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Name"    Style="{StaticResource LabelText}"/>
                    <TextBox   Grid.Row="2" Grid.Column="1"
                               Text="{Binding StepName, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Initial" Style="{StaticResource LabelText}"/>
                    <CheckBox  Grid.Row="4" Grid.Column="1"
                               IsChecked="{Binding StepIsInitial}"
                               VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="X"       Style="{StaticResource LabelText}"/>
                    <TextBox   Grid.Row="6" Grid.Column="1"
                               Text="{Binding StepX, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Y"       Style="{StaticResource LabelText}"/>
                    <TextBox   Grid.Row="8" Grid.Column="1"
                               Text="{Binding StepY, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <Separator Margin="0,4,0,4"/>

                <TextBlock Text="Actions"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>

                <ToolBar Background="{StaticResource BackgroundTertiaryBrush}">
                    <Button Content="+"
                            Command="{Binding AddActionCommand}"
                            ToolTip="Add action"/>
                    <Button Content="✕"
                            Command="{Binding RemoveActionCommand}"
                            CommandParameter="{Binding SelectedAction}"
                            ToolTip="Remove action"/>
                </ToolBar>

                <DataGrid ItemsSource="{Binding StepActions}"
                          SelectedItem="{Binding SelectedAction, Mode=TwoWay}"
                          Height="150"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridComboBoxColumn Header="Q" Width="50"
                            SelectedItemBinding="{Binding Qualifier}"
                            ItemsSource="{Binding Source={StaticResource ActionQualifiers}}"/>
                        <DataGridTextColumn Header="Variable" Width="*"
                            Binding="{Binding Variable, UpdateSourceTrigger=PropertyChanged}"/>
                        <DataGridTextColumn Header="Parameter" Width="70"
                            Binding="{Binding Parameter, UpdateSourceTrigger=PropertyChanged}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Button Content="Apply"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ApplyStepCommand}"
                        HorizontalAlignment="Right"
                        Margin="0,8,0,0"/>

            </StackPanel>

            <!-- ── Transition section ── -->
            <StackPanel Visibility="{Binding IsTransitionSelected, Converter={StaticResource BoolToVis}}">

                <TextBlock Text="Transition Properties"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>

                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Id"        Style="{StaticResource LabelText}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TransitionId}"
                               VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Condition" Style="{StaticResource LabelText}"/>
                    <TextBox   Grid.Row="2" Grid.Column="1"
                               Text="{Binding TransitionCondition, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="From Step" Style="{StaticResource LabelText}"/>
                    <TextBox   Grid.Row="4" Grid.Column="1"
                               Text="{Binding TransitionFromStepId}"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="To Step"   Style="{StaticResource LabelText}"/>
                    <TextBox   Grid.Row="6" Grid.Column="1"
                               Text="{Binding TransitionToStepId}"/>
                </Grid>

                <Button Content="Apply"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ApplyTransitionCommand}"
                        HorizontalAlignment="Right"
                        Margin="0,8,0,0"/>

            </StackPanel>

        </StackPanel>
    </ScrollViewer>

</UserControl>
