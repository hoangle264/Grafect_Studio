<UserControl x:Class="GrafcetStudio.WPF.Views.PropertiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="8">

            <!-- Header: element type -->
            <TextBlock Text="{Binding ElementType}"
                       FontWeight="SemiBold"
                       FontSize="13"
                       Foreground="{StaticResource TextPrimaryBrush}"/>

            <Separator Margin="0,6,0,0"/>

            <!-- ── Step properties ── -->
            <StackPanel Margin="0,6,0,0"
                        Visibility="{Binding IsStepSelected, Converter={StaticResource BoolToVis}}">

                <!-- Id (read-only) -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Id"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding SelectedStep.Id}"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </Grid>

                <!-- Name -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Name"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding SelectedStep.Name, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <!-- IsInitial -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Initial"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"/>
                    <CheckBox Grid.Column="1"
                              IsChecked="{Binding SelectedStep.IsInitial}"
                              VerticalAlignment="Center"/>
                </Grid>

                <!-- X -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="X"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding SelectedStep.X}"/>
                </Grid>

                <!-- Y -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Y"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding SelectedStep.Y}"/>
                </Grid>

            </StackPanel>

            <!-- ── Transition properties ── -->
            <StackPanel Margin="0,6,0,0"
                        Visibility="{Binding IsTransitionSelected, Converter={StaticResource BoolToVis}}">

                <!-- Id (read-only) -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Id"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding SelectedTransition.Id}"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </Grid>

                <!-- Condition -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Condition"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding SelectedTransition.Condition, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

            </StackPanel>

            <!-- ── Fallback: nothing selected ── -->
            <TextBlock Text="Select an element"
                       Margin="0,12,0,0"
                       FontSize="12"
                       FontStyle="Italic"
                       Foreground="{StaticResource TextDisabledBrush}"
                       Visibility="{Binding IsNothingSelected, Converter={StaticResource BoolToVis}}"/>

        </StackPanel>
    </ScrollViewer>

</UserControl>
