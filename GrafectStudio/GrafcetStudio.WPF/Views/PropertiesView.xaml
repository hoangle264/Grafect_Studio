<UserControl x:Class="GrafcetStudio.WPF.Views.PropertiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:models="clr-namespace:GrafcetStudio.Core.Models;assembly=GrafcetStudio.Core"
             prism:ViewModelLocator.AutoWireViewModel="True">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <ObjectDataProvider x:Key="ActionQualifiers"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:ActionQualifier"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Foreground"  Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Margin"      Value="0,0,0,6"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground"        Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize"          Value="11"/>
        </Style>
    </UserControl.Resources>

    <DockPanel>

        <!-- Footer: Apply / Cancel — always visible when selection exists -->
        <Border DockPanel.Dock="Bottom"
                BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource BorderSeparatorBrush}"
                Padding="8,6">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsNothingSelected}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding CancelCommand}"
                        Margin="0,0,6,0"/>
                <Button Content="Apply"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ApplyCommand}"/>
            </StackPanel>
        </Border>

        <!-- Main content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="8">

                <!-- Nothing selected -->
                <TextBlock Text="Select an element on the canvas."
                           Visibility="{Binding IsNothingSelected, Converter={StaticResource BoolToVis}}"
                           Foreground="{StaticResource TextDisabledBrush}"
                           FontStyle="Italic"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,0"/>

                <!-- ── Step section ── -->
                <StackPanel Visibility="{Binding IsStepSelected, Converter={StaticResource BoolToVis}}">

                    <TextBlock Text="Step Properties" Style="{StaticResource SectionHeader}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="28"/>
                        </Grid.RowDefinitions>

                        <!-- Id (read-only) -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Id" Style="{StaticResource FieldLabel}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding StepId}"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>

                        <!-- Name -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Name" Style="{StaticResource FieldLabel}"/>
                        <TextBox   Grid.Row="1" Grid.Column="1"
                                   Text="{Binding StepName, UpdateSourceTrigger=PropertyChanged}"
                                   VerticalAlignment="Center"/>

                        <!-- IsInitial (display-only — changing initial step requires dedicated command) -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Initial" Style="{StaticResource FieldLabel}"/>
                        <CheckBox  Grid.Row="2" Grid.Column="1"
                                   IsChecked="{Binding StepIsInitial, Mode=OneWay}"
                                   IsEnabled="False"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <Separator Margin="0,8,0,6"/>
                    <TextBlock Text="Actions" Style="{StaticResource SectionHeader}"/>

                    <!-- Action toolbar -->
                    <Button Content="+ Add Action"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding AddActionCommand}"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,4"/>

                    <!-- Actions DataGrid -->
                    <DataGrid ItemsSource="{Binding Actions}"
                              SelectedItem="{Binding SelectedAction, Mode=TwoWay}"
                              MaxHeight="200"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              SelectionMode="Single">
                        <DataGrid.Columns>

                            <!-- Qualifier -->
                            <DataGridComboBoxColumn Header="Q" Width="48"
                                SelectedItemBinding="{Binding Qualifier, UpdateSourceTrigger=PropertyChanged}"
                                ItemsSource="{Binding Source={StaticResource ActionQualifiers}}"/>

                            <!-- Variable -->
                            <DataGridTextColumn Header="Variable" Width="*"
                                Binding="{Binding Variable, UpdateSourceTrigger=PropertyChanged}"/>

                            <!-- Parameter -->
                            <DataGridTextColumn Header="Param" Width="56"
                                Binding="{Binding Parameter, UpdateSourceTrigger=PropertyChanged}"/>

                            <!-- Per-row delete button -->
                            <DataGridTemplateColumn Width="28" Header="">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✕"
                                                Style="{StaticResource IconButton}"
                                                Command="{Binding DataContext.RemoveActionCommand,
                                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Remove action"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>

                </StackPanel>

                <!-- ── Transition section ── -->
                <StackPanel Visibility="{Binding IsTransitionSelected, Converter={StaticResource BoolToVis}}">

                    <TextBlock Text="Transition Properties" Style="{StaticResource SectionHeader}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="28"/>
                        </Grid.RowDefinitions>

                        <!-- Id (read-only) -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Id" Style="{StaticResource FieldLabel}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding TransitionId}"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>

                        <!-- Condition -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Condition" Style="{StaticResource FieldLabel}"/>
                        <TextBox   Grid.Row="1" Grid.Column="1"
                                   Text="{Binding TransitionCondition, UpdateSourceTrigger=PropertyChanged}"
                                   VerticalAlignment="Center"/>
                    </Grid>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>

</UserControl>
