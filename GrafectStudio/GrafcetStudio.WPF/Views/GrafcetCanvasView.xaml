<UserControl x:Class="GrafcetStudio.WPF.Views.GrafcetCanvasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Focusable="True">

    <Grid>
        <!-- Scrollable canvas area -->
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <Grid Width="3000" Height="3000"
                  AllowDrop="True"
                  Drop="OnCanvasDrop"
                  DragOver="OnCanvasDragOver">
                <!-- Zoom transform applied to entire canvas grid -->
                <Grid.LayoutTransform>
                    <ScaleTransform ScaleX="{Binding Zoom}" ScaleY="{Binding Zoom}"/>
                </Grid.LayoutTransform>

                <!-- Dot-grid background: 20 px tile, dots at corners -->
                <Grid.Background>
                    <DrawingBrush TileMode="Tile"
                                  ViewportUnits="Absolute"
                                  Viewport="0,0,20,20">
                        <DrawingBrush.Drawing>
                            <DrawingGroup>
                                <GeometryDrawing Brush="{StaticResource CanvasBackgroundBrush}">
                                    <GeometryDrawing.Geometry>
                                        <RectangleGeometry Rect="0,0,20,20"/>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                                <GeometryDrawing Brush="{StaticResource BackgroundHoverBrush}">
                                    <GeometryDrawing.Geometry>
                                        <EllipseGeometry Center="0,0" RadiusX="1.5" RadiusY="1.5"/>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingGroup>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Grid.Background>

                <!-- Layer 1: Links (arrows) — non-interactive -->
                <ItemsControl ItemsSource="{Binding Links}" IsHitTestVisible="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Canvas>
                                <!-- Thân link -->
                                <Line X1="{Binding StartX}" Y1="{Binding StartY}"
                                      X2="{Binding EndX}"   Y2="{Binding EndY}"
                                      Stroke="{StaticResource LinkLineColorBrush}"
                                      StrokeThickness="1.5"/>
                                <!-- Mũi tên -->
                                <Path Data="{Binding ArrowGeometry}"
                                      Fill="{StaticResource LinkLineColorBrush}"
                                      Stroke="{StaticResource LinkLineColorBrush}"
                                      StrokeThickness="1"/>
                            </Canvas>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Layer 2: Transitions -->
                <ItemsControl ItemsSource="{Binding Transitions}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}"/>
                            <Setter Property="Canvas.Top"  Value="{Binding Y}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Cursor="Hand"
                                        MouseLeftButtonDown="OnElementMouseDown"
                                        MouseLeftButtonUp="OnElementMouseUp"
                                        MouseMove="OnElementMouseMove">
                                <Rectangle Width="80" Height="6"
                                           Fill="{StaticResource TransitionFillBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Condition}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontFamily="Segoe UI"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Margin="5,0,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Layer 3: Steps -->
                <ItemsControl ItemsSource="{Binding Steps}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}"/>
                            <Setter Property="Canvas.Top"  Value="{Binding Y}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="StepBorder"
                                    Width="120" Height="40"
                                    CornerRadius="2"
                                    BorderBrush="{StaticResource StepBorderBrush}"
                                    BorderThickness="2"
                                    Background="{StaticResource StepFillBrush}"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="OnElementMouseDown"
                                    MouseLeftButtonUp="OnElementMouseUp"
                                    MouseMove="OnElementMouseMove">
                                <Grid>
                                    <!-- Inner border shown only for initial step -->
                                    <Border x:Name="InitialBorder"
                                            Margin="4"
                                            BorderThickness="2"
                                            BorderBrush="Transparent"/>
                                    <TextBlock Text="{Binding Name}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontFamily="Segoe UI"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="StepBorder" Property="Background"
                                            Value="{StaticResource BackgroundSelectedBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsInitial}" Value="True">
                                    <Setter TargetName="InitialBorder" Property="BorderBrush"
                                            Value="{StaticResource StepInitialBorderBrush}"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>

        <!-- Link mode hint banner (top, visible only when IsLinkMode = True) -->
        <Border Panel.ZIndex="20"
                VerticalAlignment="Top"
                Padding="10,6">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility"  Value="Collapsed"/>
                    <Setter Property="Background"  Value="{StaticResource AccentPrimaryBrush}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLinkMode}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Command="{Binding CancelLinkCommand}"
                        Style="{StaticResource IconButton}"
                        Margin="12,0,0,0"
                        ToolTip="Cancel (Esc)">
                    <TextBlock Text="✕"
                               Foreground="{StaticResource AccentForegroundBrush}"
                               FontSize="12"/>
                </Button>
                <TextBlock Text="Link mode: click source (Step or Transition), then click target element. Invalid pairs are skipped."
                           Foreground="{StaticResource AccentForegroundBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Zoom toolbar overlay (top-right corner) -->
        <StackPanel HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Panel.ZIndex="10"
                    Orientation="Horizontal"
                    Margin="0,8,12,0">
            <Button Style="{StaticResource IconButton}"
                    Command="{Binding ZoomCommand}"
                    CommandParameter="+"
                    ToolTip="Zoom In">
                <TextBlock Text="+" FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
            </Button>
            <Button Style="{StaticResource IconButton}"
                    Command="{Binding ZoomCommand}"
                    CommandParameter="-"
                    ToolTip="Zoom Out">
                <TextBlock Text="−" FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
