<UserControl x:Class="GrafcetStudio.WPF.Views.GrafcetCanvasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Focusable="True">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.Style>
            <Style TargetType="Grid">
                <Setter Property="Cursor" Value="Arrow"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding CurrentMode,
                                     Converter={StaticResource EnumToBoolConverter},
                                     ConverterParameter=Connect}"
                                 Value="True">
                        <Setter Property="Cursor" Value="Cross"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <!-- Scrollable canvas area -->
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <Grid Width="3000" Height="3000"
                  AllowDrop="True"
                  Drop="OnCanvasDrop"
                  DragOver="OnCanvasDragOver"
                  PreviewMouseMove="OnCanvasMouseMove"
                  MouseLeftButtonUp="OnCanvasMouseUp">
                <!-- Zoom transform applied to entire canvas grid -->
                <Grid.LayoutTransform>
                    <ScaleTransform ScaleX="{Binding Zoom}" ScaleY="{Binding Zoom}"/>
                </Grid.LayoutTransform>

                <!-- Dot-grid background: 20 px tile, dots at corners -->
                <Grid.Background>
                    <DrawingBrush TileMode="Tile"
                                  ViewportUnits="Absolute"
                                  Viewport="0,0,20,20">
                        <DrawingBrush.Drawing>
                            <DrawingGroup>
                                <GeometryDrawing Brush="{StaticResource CanvasBackgroundBrush}">
                                    <GeometryDrawing.Geometry>
                                        <RectangleGeometry Rect="0,0,20,20"/>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                                <GeometryDrawing Brush="{StaticResource BackgroundHoverBrush}">
                                    <GeometryDrawing.Geometry>
                                        <EllipseGeometry Center="0,0" RadiusX="1.5" RadiusY="1.5"/>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingGroup>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Grid.Background>

                <!-- Layer 0: Branch split/merge bars — rendered below links -->
                <ItemsControl ItemsSource="{Binding Branches}" IsHitTestVisible="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><Canvas/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Canvas>
                                <!-- Split bar (double line for Parallel per IEC 60848) -->
                                <Grid>
                                    <Line X1="{Binding X}"  Y1="{Binding Y}"
                                          X2="{Binding X2}" Y2="{Binding Y}"
                                          Stroke="{StaticResource StepBorderBrush}"
                                          StrokeThickness="2"/>
                                    <Line X1="{Binding X}"  Y1="{Binding Y2Offset}"
                                          X2="{Binding X2}" Y2="{Binding Y2Offset}"
                                          Stroke="{StaticResource StepBorderBrush}"
                                          StrokeThickness="2"
                                          Visibility="{Binding IsParallel,
                                              Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </Grid>
                                <!-- Merge bar (double line for Parallel per IEC 60848) -->
                                <Grid>
                                    <Line X1="{Binding X}"  Y1="{Binding MergeY}"
                                          X2="{Binding X2}" Y2="{Binding MergeY}"
                                          Stroke="{StaticResource StepBorderBrush}"
                                          StrokeThickness="2"/>
                                    <Line X1="{Binding X}"  Y1="{Binding MergeY2Offset}"
                                          X2="{Binding X2}" Y2="{Binding MergeY2Offset}"
                                          Stroke="{StaticResource StepBorderBrush}"
                                          StrokeThickness="2"
                                          Visibility="{Binding IsParallel,
                                              Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </Grid>
                            </Canvas>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Layer 1: Links (arrows) — selectable and deletable -->
                <ItemsControl ItemsSource="{Binding Links}" IsHitTestVisible="True">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Canvas>
                                <Canvas.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.SelectElementCommand,
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Canvas.InputBindings>
                                <Path x:Name="LinkPath"
                                      Data="{Binding LinePath}"
                                      Stroke="{StaticResource LinkLineColorBrush}"
                                      StrokeThickness="1.5"
                                      Fill="Transparent"/>
                                <Path x:Name="ArrowPath"
                                      Data="{Binding ArrowGeometry}"
                                      Fill="{StaticResource LinkLineColorBrush}"
                                      Stroke="{StaticResource LinkLineColorBrush}"
                                      StrokeThickness="1"/>
                            </Canvas>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="LinkPath"  Property="Stroke"          Value="{StaticResource AccentPrimaryBrush}"/>
                                    <Setter TargetName="LinkPath"  Property="StrokeThickness" Value="2.5"/>
                                    <Setter TargetName="ArrowPath" Property="Fill"            Value="{StaticResource AccentPrimaryBrush}"/>
                                    <Setter TargetName="ArrowPath" Property="Stroke"          Value="{StaticResource AccentPrimaryBrush}"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Layer 2: Transitions -->
                <ItemsControl ItemsSource="{Binding Transitions}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}"/>
                            <Setter Property="Canvas.Top"  Value="{Binding Y}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Cursor="Hand"
                                        MouseLeftButtonDown="OnElementMouseDown"
                                        MouseLeftButtonUp="OnElementMouseUp"
                                        MouseMove="OnElementMouseMove">
                                <Rectangle Width="80" Height="6"
                                           Fill="{StaticResource TransitionFillBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Condition}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontFamily="Segoe UI"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Margin="5,0,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Layer 3: Steps -->
                <ItemsControl ItemsSource="{Binding Steps}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}"/>
                            <Setter Property="Canvas.Top"  Value="{Binding Y}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Cursor="Hand"
                                        MouseLeftButtonDown="OnElementMouseDown"
                                        MouseLeftButtonUp="OnElementMouseUp"
                                        MouseMove="OnElementMouseMove">
                                <!-- Main step box - displays Step ID -->
                                <Border x:Name="StepBorder"
                                        Width="120" Height="40"
                                        CornerRadius="2"
                                        BorderBrush="{StaticResource StepBorderBrush}"
                                        BorderThickness="2"
                                        Background="{StaticResource StepFillBrush}">
                                    <Grid>
                                        <!-- Inner border shown only for initial step -->
                                        <Border x:Name="InitialBorder"
                                                Margin="4"
                                                BorderThickness="2"
                                                BorderBrush="Transparent"/>
                                        <TextBlock Text="{Binding StepDisplayText}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontFamily="Segoe UI"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </Grid>
                                </Border>

                                </StackPanel>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter TargetName="StepBorder" Property="Background"
                                                Value="{StaticResource BackgroundSelectedBrush}"/>
                                    </DataTrigger>
                                <DataTrigger Binding="{Binding IsInitial}" Value="True">
                                    <Setter TargetName="InitialBorder" Property="BorderBrush"
                                            Value="{StaticResource StepInitialBorderBrush}"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Layer 4: Ghost line overlay for drag-to-create-link -->
                <Line X1="{Binding GhostX1}" Y1="{Binding GhostY1}"
                      X2="{Binding GhostX2}" Y2="{Binding GhostY2}"
                      Stroke="{StaticResource AccentPrimaryBrush}"
                      StrokeThickness="2"
                      StrokeDashArray="4 2"
                      IsHitTestVisible="False"
                      Panel.ZIndex="20"
                      Visibility="{Binding GhostLineVisible,
                          Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>
        </ScrollViewer>

        <!-- Link mode hint banner (top, visible only when IsLinkMode = True) -->
        <Border Panel.ZIndex="20"
                VerticalAlignment="Top"
                Padding="10,6">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility"  Value="Collapsed"/>
                    <Setter Property="Background"  Value="{StaticResource AccentPrimaryBrush}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLinkMode}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Command="{Binding CancelLinkCommand}"
                        Style="{StaticResource IconButton}"
                        Margin="12,0,0,0"
                        ToolTip="Cancel (Esc)">
                    <TextBlock Text="✕"
                               Foreground="{StaticResource AccentForegroundBrush}"
                               FontSize="12"/>
                </Button>
                <TextBlock Text="Link mode: click source (Step or Transition), then click target element. Invalid pairs are skipped."
                           Foreground="{StaticResource AccentForegroundBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Mode toolbar overlay (top-left corner) -->
        <StackPanel HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Panel.ZIndex="10"
                    Orientation="Horizontal"
                    Margin="12,8,0,0">
            <ToggleButton Content="↖ Select"
                          Style="{StaticResource ModeToggleButton}"
                          IsChecked="{Binding CurrentMode,
                              Converter={StaticResource EnumToBoolConverter},
                              ConverterParameter=Select}"
                          ToolTip="Select / Move mode"/>
            <ToggleButton Content="⟶ Connect"
                          Style="{StaticResource ModeToggleButton}"
                          IsChecked="{Binding CurrentMode,
                              Converter={StaticResource EnumToBoolConverter},
                              ConverterParameter=Connect}"
                          Margin="4,0,0,0"
                          ToolTip="Connect / Link mode"/>
        </StackPanel>

        <!-- Zoom toolbar overlay (top-right corner) -->
        <StackPanel HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Panel.ZIndex="10"
                    Orientation="Horizontal"
                    Margin="0,8,12,0">
            <Button Style="{StaticResource IconButton}"
                    Command="{Binding ZoomCommand}"
                    CommandParameter="+"
                    ToolTip="Zoom In">
                <TextBlock Text="+" FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
            </Button>
            <Button Style="{StaticResource IconButton}"
                    Command="{Binding ZoomCommand}"
                    CommandParameter="-"
                    ToolTip="Zoom Out">
                <TextBlock Text="−" FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
