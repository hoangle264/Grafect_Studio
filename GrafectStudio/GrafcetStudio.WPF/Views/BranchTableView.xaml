<UserControl x:Class="GrafcetStudio.WPF.Views.BranchTableView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:models="clr-namespace:GrafcetStudio.Core.Models;assembly=GrafcetStudio.Core"
             prism:ViewModelLocator.AutoWireViewModel="True">

    <UserControl.Resources>
        <ObjectDataProvider x:Key="BranchTypes"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:BranchType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>

    <DockPanel>
        <!-- Toolbar: Add / Remove branch -->
        <ToolBar DockPanel.Dock="Top"
                 Background="{StaticResource BackgroundTertiaryBrush}">
            <Button Style="{StaticResource IconButton}"
                    Command="{Binding AddBranchCommand}"
                    ToolTip="Add branch">
                <TextBlock Text="+" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
            </Button>
            <Button Style="{StaticResource IconButton}"
                    Command="{Binding RemoveBranchCommand}"
                    ToolTip="Remove branch">
                <TextBlock Text="✕" FontSize="11"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
            </Button>
        </ToolBar>

        <!-- Branch table -->
        <DataGrid ItemsSource="{Binding Branches}"
                  SelectedItem="{Binding SelectedBranch, Mode=TwoWay}"
                  CanUserAddRows="False"
                  AutoGenerateColumns="False"
                  ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                  RowStyle="{StaticResource DataGridRowStyle}"
                  CellStyle="{StaticResource DataGridCellStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                                    Binding="{Binding Id}"
                                    Width="40"
                                    IsReadOnly="True"/>
                <DataGridComboBoxColumn Header="Type"
                                        Width="100"
                                        SelectedValueBinding="{Binding Type, UpdateSourceTrigger=PropertyChanged}">
                    <DataGridComboBoxColumn.ItemsSource>
                        <Binding Source="{StaticResource BranchTypes}"/>
                    </DataGridComboBoxColumn.ItemsSource>
                </DataGridComboBoxColumn>
                <DataGridTextColumn Header="Split Step"
                                    Binding="{Binding SplitStepId, UpdateSourceTrigger=PropertyChanged}"
                                    Width="80"/>
                <DataGridTextColumn Header="Branch Steps"
                                    Binding="{Binding BranchStepIds, UpdateSourceTrigger=PropertyChanged}"
                                    Width="110"/>
                <DataGridTextColumn Header="Merge Step"
                                    Binding="{Binding MergeStepId, UpdateSourceTrigger=PropertyChanged}"
                                    Width="80"/>
                <DataGridTextColumn Header="Description"
                                    Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
